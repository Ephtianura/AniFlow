{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ]
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000" ]
  },

  "ConnectionStrings": {
    "AnimeAppDbContext": "Host=host.docker.internal;Port=5432;Database='AnimeAppDb';Username=postgres;Password=54321",
    "Redis": "host.docker.internal:6379,abortConnect=false,connectRetry=3,connectTimeout=5000"
  },

  "JwtOptions": {
    "Secretkey": "secretkeysecretkeysecretkeysecretkeysecretkeysecretkeysecretkey",
    "ExpiresHours": "168"
  },

  "RabbitMQ": {
    "Host": "host.docker.internal",
    "Username": "admin",
    "Password": "admin"
  },

  "AWS": {
    "PublicUrl": "http://localhost:9000/images",
    "AccessKey": "admin",
    "SecretKey": "secret123",
    "ServiceURL": "http://host.docker.internal:9000/images",
    "BucketName": "images",
    "ForcePathStyle": true,
    "Region": "us-east-1"
  }
}